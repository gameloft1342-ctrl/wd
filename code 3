Develop a responsive web page using Bootstrap Grid and Components. 
<!DOCTYPE html> 
<html> 
<head> 
    <title>Bootstrap Example</title> 
    <!-- Bootstrap CSS --> 
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" 
rel="stylesheet"> 
</head> 
<body> 
<!-- Heading --> 
<div class="container text-center mt-3"> 
    <h1>My Web Page</h1> 
</div> 
<!-- Grid --> 
<div class="container mt-4"> 
    <div class="row"> 
        <div class="col-md-4 bg-primary text-white p-3"> 
            Column 1 
        </div> 
        <div class="col-md-4 bg-success text-white p-3"> 
            Column 2 
        </div> 
        <div class="col-md-4 bg-danger text-white p-3"> 
            Column 3 
        </div> 
</div> 
</div> 
<!-- Button --> 
<div class="container text-center mt-4"> 
<button class="btn btn-warning">Click Me</button> 
</div> 
</body> 
</html>
