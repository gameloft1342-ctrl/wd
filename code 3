3.. Create a form with fields: name, email, gender, date of birth, and submit button. 
<!DOCTYPE html> 
<html> 
<head> 
    <title>Simple Form</title> 
</head> 
<body> 
<h2>Registration Form</h2> 
<form> 
    <!-- Name --> 
    <label for="name">Full Name:</label><br> 
    <input type="text" id="name" name="name" placeholder="Enter your name" 
required><br><br> 
    <!-- Email --> 
    <label for="email">Email:</label><br> 
    <input type="email" id="email" name="email" placeholder="Enter your email" 
required><br><br> 
    <!-- Gender --> 
    <label>Gender:</label><br> 
    <div> 
        <label><input type="radio" name="gender" value="Male"> Male</label><br> 
        <label><input type="radio" name="gender" value="Female"> Female</label><br> 
        <label><input type="radio" name="gender" value="Other"> Other</label> 
    </div><br> 
    <!-- Date of Birth --> 
    <label for="dob">Date of Birth:</label><br> 
    <input type="date" id="dob" name="dob" required><br><br> 
<!-- Submit --> 
<button type="submit">Submit</button> 
</form> 
</body> 
</html> 
Apply internal, external, and inline CSS to style a web page with headings and tables. 
<!DOCTYPE html> 
<html> 
<head> 
    <title>CSS Example</title> 
    <!-- Internal CSS --> 
    <style> 
        body { 
            font-family: Arial; 
            background-color: white; 
        } 
        h1 { 
            text-align: center; 
        } 
        table { 
            width: 50%; 
            margin:auto; 
        } 
        th, td { 
            border: 1px solid black; 
            padding: 10px; 
            text-align: center; 
        } 
        th { 
            background-color: lightgray; 
        } 
    </style> 
    <!-- External CSS --> 
    <link rel="stylesheet" href="style.css"> 
</head> 
<body> 
    <!-- Inline CSS --> 
    <h1 style="color: blue">Student Information</h1> 
    <table> 
        <tr> 
            <th>Name</th> 
            <th>Marks</th> 
        </tr> 
        <tr> 
            <td>Amit</td> 
            <td>85</td> 
        </tr> 
        <tr> 
            <td>Priya</td> 
            <td>90</td> 
        </tr> 
    </table> 
</body> 
</html> 
 
 
 
